{
  "name": "@videoshare/desktop",
  "version": "1.3.3",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --configLoader native",
    "build": "node -e \"const fs=require('fs');fs.mkdirSync('src-tauri/build',{recursive:true});fs.writeFileSync('src-tauri/build/EULA.txt',fs.readFileSync('../../LICENSE')+'\\n\\n'+fs.readFileSync('../../NOTICE'))\" && tsc -p tsconfig.json && vite build --configLoader native",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "tauri:dev": "tauri dev",
    "tauri:dev:debug": "tauri dev",
    "tauri:dev:release": "tauri dev --release",
    "tauri:build": "tauri build --config src-tauri/tauri.release.conf.json",
    "tauri:clean": "cargo clean --manifest-path src-tauri/Cargo.toml"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.3.0",
    "@videoshare/shared-types": "0.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.3.1",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^5.0.0",
    "vite": "^6.2.2"
  }
}

{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": false,
    "resolveJsonModule": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@videoshare/shared-types": ["packages/shared-types/src/index.ts"],
      "@videoshare/shared-schemas": ["packages/shared-schemas/src/index.ts"],
      "@videoshare/shared-utils": ["packages/shared-utils/src/index.ts"]
    }
  }
}
